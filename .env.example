# Absolute path to the Obsidian vault Mission Control reads from.
# On trav-dev: /home/brad/Documents/Traversy Lab
# On trav-ai (prod): set to the mounted vault path on that machine
VAULT_PATH=/home/brad/Documents/Traversy Lab

# Port next start binds to in production (trav-ai).
# Dev server ignores this and uses 3000 via `next dev`.
PORT=8890

# GitHub personal access token for the GitHub Activity tab. Optional — without
# it the tab renders an empty state. Required to read travxlabs/* (private
# repos). Fine-grained PAT scoped to the travxlabs org with `metadata: read`
# and `contents: read` is sufficient. Create at github.com/settings/tokens.
GITHUB_TOKEN=

# GitHub org / user whose repos appear on the GitHub tab. Defaults to
# travxlabs.
GITHUB_ORG=travxlabs
