# Absolute path to the Obsidian vault Mission Control reads from. Required.
VAULT_PATH=/path/to/your/obsidian/vault

# Port next start binds to in production. Dev server ignores this and uses
# 3000 via `next dev`.
PORT=3000

# GitHub personal access token for the GitHub Activity tab. Optional —
# without it the tab renders an empty state. Required to read private
# repos. A fine-grained PAT with `metadata: read` and `contents: read` on
# the relevant accounts is sufficient. Create at github.com/settings/tokens.
GITHUB_TOKEN=

# Comma-separated GitHub accounts (users or orgs) to surface on the GitHub
# tab. Each gets its own contribution calendar + repos grid; events from all
# accounts are merged into one activity feed. The legacy GITHUB_ORG env var
# is still accepted as a single-account fallback.
GITHUB_ACCOUNTS=your-username
